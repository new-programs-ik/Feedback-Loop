# ─────────────────────────────────────────────────────────────────────────────
# Ratings & Feedback module — configuration template (§10).
# Copy to `.env` and fill in. NEVER commit the real `.env` (it is gitignored).
# In n8n, store the same secrets as n8n *credentials*, not in workflow bodies.
# ─────────────────────────────────────────────────────────────────────────────

# --- Engine (M1/M3) ---------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# --- Postgres store (M1) ----------------------------------------------------
# Supabase or Neon. SQLAlchemy URL form; +psycopg2 is the default driver.
# e.g. postgresql+psycopg2://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME

# --- Metabase ingest (M2) ---------------------------------------------------
METABASE_URL=https://metabase.example.com
METABASE_API_KEY=                 # preferred: a Metabase API key (X-API-KEY)
# ...or session auth (used only if no API key):
METABASE_USERNAME=
METABASE_PASSWORD=
# How to query the weekly low-rated list — pick ONE:
METABASE_CARD_ID=                 # a saved question/card id (recommended), OR
METABASE_DATABASE_ID=             # + raw SQL via a dataset query (advanced)
# Comma-separated courses this run is scoped to (the PM's assigned courses):
ASSIGNED_COURSES=

# --- Uplevel transcript source (M2 / §6.6) ----------------------------------
UPLEVEL_BASE_URL=https://uplevel.interviewkickstart.com
# Preferred: a platform-issued service/API token (clean path):
UPLEVEL_API_TOKEN=
# Fallback: Cognito refresh-token flow (us-west-2). NEVER use captured cookies.
COGNITO_CLIENT_ID=
COGNITO_REFRESH_TOKEN=
COGNITO_REGION=us-west-2

# --- Notifications (M4/M7/M8) — set in n8n credentials in production ---------
SLACK_BOT_TOKEN=                  # xoxb-...
SLACK_PM_CHANNEL_ID=              # the PM group channel id (Cxxxxxxxx)
DISCORD_BOT_TOKEN=

# --- UI ---------------------------------------------------------------------
UI_URL=https://ratings-ui.example.com
